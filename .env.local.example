# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# 토스페이먼츠
TOSS_CLIENT_KEY=your-toss-client-key
TOSS_SECRET_KEY=your-toss-secret-key

# Anthropic (Claude API)
ANTHROPIC_API_KEY=your-anthropic-api-key

# YouTube Data API v3
YOUTUBE_API_KEY=your-youtube-api-key

# AssemblyAI
ASSEMBLYAI_API_KEY=your-assemblyai-api-key

# KYC 암호화 키 (AES-256, 64자 hex)
# 생성: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
KYC_ENCRYPTION_KEY=your-64-char-hex-key

# Vercel Cron 인증 (64자 hex)
# Vercel이 cron 호출 시 Authorization: Bearer <CRON_SECRET> 헤더로 검증
CRON_SECRET=your-cron-secret
